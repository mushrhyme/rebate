# 비워두면 Vite 프록시를 통해 /api/* → 백엔드로 자동 포워딩
# 외부 서버에 직접 연결하려면 아래 주석 해제
# VITE_API_URL=http://your-server-ip:8800
VITE_API_URL=

# Vite 프록시가 /api를 넘길 백엔드 대상 (PC마다 다를 수 있음)
# 포트만 다르면 VITE_BACKEND_PORT 만 지정. 기본 8800.
# VITE_BACKEND_PORT=8800
# 전체 URL을 직접 지정하려면 (우선 적용):
# VITE_PROXY_TARGET=http://localhost:8000
