AZURE_API_KEY=your_azure_document_intelligence_key
AZURE_API_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

ANTHROPIC_API_KEY=your_anthropic_api_key

# JWT (배포 시 openssl rand -hex 32 로 생성)
JWT_SECRET=your_jwt_secret_here

# AWS S3
AWS_S3_BUCKET=your-s3-bucket-name

# Google Sheets 매핑 (GOOGLE_SHEETS_MAPPINGS_ID 설정 시 활성화)
# 인증: ~/.google-cli/token.pickle (Google CLI OAuth)
GOOGLE_SHEETS_MAPPINGS_ID=your_spreadsheet_id

# Phase 3 Tool Use (기본 OFF — true로 설정 시 Claude tool_use 경로 활성화)
PHASE3_TOOL_USE_ENABLED=false
# PHASE3_TOOL_USE_CONCURRENCY=3        # 문서 내부 동시 항목 처리 수 (기본 1)
# PHASE3_TOOL_USE_GLOBAL_CONCURRENCY=3 # 전체 동시 문서 수 상한 (기본 3)

# 파이프라인 동시 처리 수 (기본값으로 충분한 경우 설정 불필요)
# MAX_CONCURRENT_ANALYSES=5      # 동시 파이프라인 실행 상한 (기본 5)
# MAX_CONCURRENT_PHASE2_CHUNKS=3 # Phase 2 청크 동시 실행 상한 (기본 3)

# 양식 삭제 관리자 비밀번호 (설정하지 않으면 삭제 불가)
# ADMIN_DELETE_PASSWORD=your_admin_password

# Google Drive G2 연동 (선택 — setup_g2.py 실행 후 설정)
# DRIVE_INBOX_FOLDER_ID=your_inbox_folder_id
# DRIVE_ARCHIVE_FOLDER_ID=your_archive_folder_id
# DRIVE_INBOX_POLL_INTERVAL=300
